# Copy to secret.yaml, fill in real values, and DO NOT commit it.
# In production, prefer External Secrets Operator / Sealed Secrets over
# committing rendered Secret manifests to the cluster's Git repo.
apiVersion: v1
kind: Secret
metadata:
  name: rag-api-secrets
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://user:password@postgres-host:5432/rag_platform"
  JWT_SECRET_KEY: "REPLACE_WITH_LONG_RANDOM_STRING"
  ANTHROPIC_API_KEY: "REPLACE_WITH_KEY"
  QDRANT_URL: "http://qdrant:6333"
  QDRANT_API_KEY: ""
